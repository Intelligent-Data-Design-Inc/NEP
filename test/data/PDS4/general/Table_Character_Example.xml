                        <missing_constant>-999.9</missing_constant>
                    </Special_Constants>
                </Field_Character>
                
                <Field_Character>
                    <name>Error</name>
                    <field_number>3</field_number>
                    <field_location unit="byte">20</field_location>
                    <data_type>ASCII_Real</data_type>
                    <field_length unit="byte">10</field_length>
                </Field_Character>
