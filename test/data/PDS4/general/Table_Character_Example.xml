                </Field_Character>
                
                <Field_Character>
                    <name>Reflectance</name>
                    <field_number>2</field_number>
                    <field_location unit="byte">10</field_location>
                    <data_type>ASCII_Real</data_type>
                    <field_length unit="byte">10</field_length>
