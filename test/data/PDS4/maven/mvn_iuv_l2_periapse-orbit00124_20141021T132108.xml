<Modification_History>
  <Modification_Detail>
    <modification_date>2015-07-28</modification_date>
    <version_id>1.0</version_id>
    <description>First PDS release of IUVS products</description>
  </Modification_Detail>
  <Modification_Detail>
    <modification_date>2015-08-18</modification_date>
    <version_id>2.0</version_id>
    <description>Second PDS release. This collection is only extended with new data -- no data from the previous version has been reprocessed</description>
  </Modification_Detail>
  <Modification_Detail>
    <modification_date>2015-11-16</modification_date>
    <version_id>3.0</version_id>
    <description>Third PDS release. Additional upper-level products have been added, and uncertainty has been modified in level 1C periapse. All products have been reprocessed with the new software, even if this would not change the data.</description>
  </Modification_Detail>
  <Modification_Detail>
    <modification_date>2016-02-08</modification_date>
    <version_id>4.0</version_id>
    <description>Fourth PDS release. Wavelength scale is improved in level 1B, and all upper-level products use this modified wavelength scale. Additional upper-level products have been added. All products have been reprocessed with the new software, even if this would not change the data.</description>
  </Modification_Detail>
  <Modification_Detail>
    <modification_date>2016-05-10</modification_date>
    <version_id>5.0</version_id>
    <description>Fifth PDS release. This collection is only extended with new data -- no data from the previous version has been reprocessed.</description>
  </Modification_Detail>
  <Modification_Detail>
    <modification_date>2016-08-15</modification_date>
    <version_id>6.0</version_id>
    <description>Sixth PDS release. A bug in dark subtraction has been fixed.</description>
  </Modification_Detail>
  <Modification_Detail>
    <modification_date>2016-11-15</modification_date>
    <version_id>7.0</version_id>
    <description>Seventh PDS release. Periapse retrieval is based on DN, rather than calibrated, images. MUV calibration curve shifted 7nm. Several pixel geometry fields have been modified.</description>
  </Modification_Detail>
  <Modification_Detail>
    <modification_date>2018-02-15</modification_date>
    <version_id>12.0</version_id>
    <description>Twelfth PDS release. A bug in special observations where the scan mirror was commanded to not move has been fixed. A bug that caused some special observations late in an orbit to have the wrong orbit number has been fixed.</description>
  </Modification_Detail>
  <Modification_Detail>
    <modification_date>2018-06-28</modification_date>
    <version_id>13.0</version_id>
    <description>Thirteenth PDS release. Full mission reprocess and changes to L1C airglow templates.</description>
  </Modification_Detail>
</Modification_History>
